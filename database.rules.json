{
  "rules": {
    ".read": false,
    ".write": false,
    "employees": {
      ".read": true,
      ".write": true,
      "$employeeId": {
        ".validate": "newData.hasChildren(['name','hourlyRate']) && newData.child('name').isString() && newData.child('hourlyRate').isNumber()"
      }
    },
    "payrollHistory": {
      ".read": true,
      ".write": true,
      "$payrollId": {
        ".validate": "newData.hasChildren(['employeeId','employeeName','weekEnding','hourlyRate','totalHours','grossPay'])"
      }
    }
  }
}
